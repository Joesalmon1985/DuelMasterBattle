; Engine configuration file.
config_version=5

[application]
config/name="DuelMasterBattle"
config/description="Duelling Mastermind — authoritative sim + client"
run/main_scene="res://client/scenes/main_menu.tscn"
config/features=PackedStringArray("4.4")

[autoload]
EncounterSession="*res://client/scripts/encounter_session.gd"

[display]
window/size/viewport_width=900
window/size/viewport_height=700
window/stretch/mode="canvas_items"

[rendering]
renderer/rendering_method="gl_compatibility"
